# ================================================================
# KOPERASI BERJALAN - ENVIRONMENT CONFIGURATION EXAMPLE
# Copy this file to .env and update with your actual credentials
# Updated: 27 Maret 2026 - Database Integration Ready
# ================================================================

# Database Configuration (Multi-Schema)
DB_HOST=localhost
DB_PORT=3306
DB_SOCKET=/opt/lampp/var/mysql/mysql.sock
DB_USERNAME=root
DB_PASSWORD=root
DB_SCHEMA_PERSON=schema_person
DB_SCHEMA_ADDRESS=schema_address
DB_SCHEMA_APP=schema_app

# Application Configuration
APP_NAME=Koperasi Berjalan
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost/gabe
APP_VERSION=1.1.0

# Security Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE_HOURS=24
BCRYPT_ROUNDS=12

# XAMPP Configuration
XAMPP_ROOT=/opt/lampp
MYSQL_SOCKET=/opt/lampp/var/mysql/mysql.sock

# Sudo Configuration (for system operations)
SUDO_USER=8208
SUDO_PASSWORD=8208

# File Upload Configuration
MAX_FILE_SIZE=10MB
UPLOAD_PATH=/opt/lampp/htdocs/gabe/uploads/

# Email Configuration (if needed)
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls

# SMS Configuration (if needed)
SMS_PROVIDER=
SMS_API_KEY=
SMS_API_SECRET=

# Backup Configuration
BACKUP_PATH=/opt/lampp/htdocs/gabe/database/
BACKUP_RETENTION_DAYS=30

# Logging Configuration
LOG_PATH=/opt/lampp/htdocs/gabe/logs/
LOG_LEVEL=info

# Performance Configuration
CACHE_DRIVER=file
SESSION_LIFETIME=120

# API Configuration
API_RATE_LIMIT=1000
API_TIMEOUT=30000

# Development Configuration
DEV_MODE=false
SHOW_ERRORS=false
DEBUG_QUERIES=false
